# EmailJS Configuration
# Instructions:
# 1. Sign up for a free account at https://dashboard.emailjs.com/
# 2. Create an Email Service and copy the Service ID
# 3. Create an Email Template and copy the Template ID
# 4. Go to Account Settings and copy your Public Key
# 5. Replace the values below with your actual IDs

VITE_APP_EMAILJS_SERVICE_ID=service_xxxxxxxxxxxxx
VITE_APP_EMAILJS_TEMPLATE_ID=template_xxxxxxxxxxxxx
VITE_APP_EMAILJS_PUBLIC_KEY=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
